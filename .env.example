# invest-simulator environment variables
# Copy this file to .env.local for local development; fill in values.
# NEVER prefix any key with NEXT_PUBLIC (Phase 01 D-21: all secrets are server-only).
# Do NOT commit .env.local.
#
# For production (Vercel): register each variable below via the Vercel
# Dashboard UI (Project → Settings → Environment Variables) — Phase 05 D-08.
# Do NOT use `vercel env add` CLI.

# -- Database -----------------------------------------------------------
# Neon Postgres pooled connection URL (used by the app at runtime).
# Get from: Neon Console → Connection Details → Pooled connection
DATABASE_URL=

# Neon Postgres direct connection URL — LOCAL MIGRATE ONLY.
# drizzle-kit migrate requires a non-pooled connection. Not needed in
# Vercel Production env vars (we do not run migrate in production).
DATABASE_URL_DIRECT=

# -- AI (Gemini) --------------------------------------------------------
# Google Gemini API key. Get from https://aistudio.google.com/apikey
# Free tier (1,500 req/day) covers the 1-run/day cron (Phase 01 pivot).
GEMINI_API_KEY=

# -- Auth (iron-session v8) --------------------------------------------
# Cookie encryption secret. MUST be ≥32 chars (enforced by lib/env.ts zod).
# Generate with: openssl rand -base64 48
# Rotation: manual, annual (Phase 05 D-09).
SESSION_SECRET=

# Plaintext dashboard password (compared with timingSafeEqual).
SITE_PASSWORD=

# -- Vercel Cron -------------------------------------------------------
# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`.
# Generate with: openssl rand -hex 32
# In Vercel Dashboard, enable this variable for PRODUCTION ONLY
# (Pitfall 8: Preview cron invocations are not needed).
CRON_SECRET=

# -- Market Data (Phase 02) --------------------------------------------
# Finnhub API key for US stock news + basic financials.
# Free tier: https://finnhub.io/register (60 calls/min, US only)
FINNHUB_API_KEY=
