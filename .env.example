# invest-simulator environment variables
# Copy this file to .env.local and fill in values.
# NEVER add the NEXT_PUBLIC prefix to any of these keys (D-21: all secrets are server-only).
# Do NOT commit .env.local.

# Neon Postgres direct connection URL (not pooled; pooled URL breaks drizzle-kit migrate).
# Get from: Neon Console -> Connection Details -> Direct connection
DATABASE_URL=
DATABASE_URL_DIRECT=

# Anthropic API key for Claude (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=

# iron-session cookie encryption secret (MUST be at least 32 bytes)
# Generate with: openssl rand -base64 48
SESSION_SECRET=

# Plaintext dashboard password (D-16: timingSafeEqual compared)
SITE_PASSWORD=

# Shared secret for Vercel Cron endpoint protection (Phase 5)
CRON_SECRET=
